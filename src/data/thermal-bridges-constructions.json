{
  "_meta": {
    "version": "1.0.0",
    "created": "2026-04-24",
    "purpose": "Catalog stratigrafii tipice românești pentru elementele de anvelopă + factori corecție ψ per tipologie punte termică.",
    "normative_basis": [
      "C107/3-2005 — Anexele E (valori lambda), G (clasificare punți), K (catalog punți uzuale) [în vigoare, consolidat Ord. 2513/2010, Ord. 386/2016]",
      "C107/1-2005 — Calcul coeficienți globali (Tab. 1-73 pentru pereți, Tab. 1-18 pentru planșee)",
      "C107/6-2002 — Calcul termotehnic pardoseli",
      "Mc 001-2022 — Anexa B (punți în audit), Anexa G (straturi tipice RO), Ord. 16/2023 (MDLPA)",
      "SR EN ISO 6946:2017 — Rezistență termică elemente stratificate (metodă de calcul)",
      "SR EN ISO 12524 / EN ISO 10456 — Valori de proiectare λ pentru materiale construcție",
      "SR EN ISO 13370:2017 — Transfer termic prin sol",
      "SR EN ISO 14683:2017 — Punți termice liniare (valori implicite)",
      "SR EN ISO 10211:2017 — Calcule detaliate punți termice (2D/3D)",
      "SR EN ISO 10077-1 — Tâmplărie exterioară",
      "SR EN ISO 13788 — Condens superficial și interstițial (fRsi)",
      "SR EN ISO 52016-1:2017 + A1:2025 — Sarcini termice orar (per strat)",
      "EN 13162-13171 — Specificații izolații: MW/EPS/XPS/PUR/PF/EPB"
    ],
    "lambda_sources": {
      "EPS": "EN 13163 + C107/3 Anexa E (λ = 0,036...0,044 W/(m·K) funcție densitate, calitatea, umiditatea)",
      "XPS": "EN 13164 (λ = 0,033...0,038 W/(m·K))",
      "MW_vata": "EN 13162 (λ = 0,035...0,045 W/(m·K) funcție densitate 30-150 kg/m³)",
      "PUR_PIR": "EN 13165 (λ = 0,022...0,028 W/(m·K))",
      "caramida_plina": "C107/3 Anexa E (λ = 0,80 W/(m·K) ρ≈1800 kg/m³)",
      "caramida_GVP": "C107/3 Anexa E (λ = 0,36...0,55 W/(m·K) funcție tip goluri)",
      "BCA_450": "C107/3 Anexa E (λ = 0,11 W/(m·K) ρ≈450 kg/m³)",
      "BCA_700": "C107/3 Anexa E (λ = 0,27 W/(m·K) ρ≈700 kg/m³)",
      "beton_armat": "C107/3 Anexa E (λ = 1,74...2,03 W/(m·K))",
      "lemn_moale": "C107/3 Anexa E (λ = 0,13 W/(m·K) pin/brad)",
      "OSB_CLT": "EN 312, EN 13986 (λ = 0,13 W/(m·K))",
      "gips_carton": "C107/3 Anexa E (λ = 0,21 W/(m·K))",
      "tencuiala_var": "C107/3 Anexa E (λ = 0,70 W/(m·K))",
      "tencuiala_ciment": "C107/3 Anexa E (λ = 0,93 W/(m·K))",
      "sapa_beton": "C107/3 Anexa E (λ = 1,40 W/(m·K))"
    },
    "Rsi_Rse": {
