# App version afișat în UI și documente (S30A·A5)
# Default fallback "v3.5" în src/data/app-version.js dacă variabila lipsește.
VITE_APP_VERSION=v3.5

# Supabase (required for auth and database)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase service key (server-side only — for webhooks)
SUPABASE_SERVICE_KEY=your-service-role-key

# Stripe (for payment processing)
VITE_STRIPE_PUBLIC_KEY=pk_test_your-stripe-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_PRO=price_your-pro-price-id
STRIPE_PRICE_BUSINESS=price_your-business-price-id

# Anthropic (server-side only — used by api/ai-assistant.js)
# Do NOT prefix with VITE_ — this must stay server-side only
ANTHROPIC_API_KEY=sk-ant-your-key
